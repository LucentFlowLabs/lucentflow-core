# Database Configuration
POSTGRES_DB="lucentflow"
POSTGRES_USER="admin"
# DEFAULT: Set to 'lucentflow_pwd' for instant 1-click startup. 
# CHANGE THIS if deploying to a public-facing server.
POSTGRES_PASSWORD=lucentflow_pwd

# Network Proxy (Optional - for corporate environments)
PROXY_HOST=""
PROXY_PORT=""

# Base Network Integration (Mandatory for Genesis Trace)
BASESCAN_API_KEY=""
BASESCAN_BASE_URL="https://api.basescan.org/api"
LUCENTFLOW_CHAIN_RPC_URL="https://mainnet.base.org"

# Spring Profiles
SPRING_PROFILES_ACTIVE="docker"

# JVM Optimization
JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational -Xms512m -Xmx2g"
