# ==============================================================================
# LucentFlow — Docker environment template
# Copy to `.env` in this directory and adjust. Convention: mainnet.base.org uses built-in safe pacing;
# .env indexer tuning applies only when LUCENTFLOW_CHAIN_RPC_URL is NOT the official Base public host.
# ==============================================================================

# --- Database ---
POSTGRES_DB="lucentflow"
POSTGRES_USER="admin"
POSTGRES_PASSWORD=lucentflow_pwd

# --- Base L2 RPC ---
LUCENTFLOW_CHAIN_RPC_URL=https://mainnet.base.org
LUCENTFLOW_CHAIN_RPC_BACKUP_URL=https://mainnet.base.org

# --- Basescan (required for deep funding traces) ---
BASESCAN_API_KEY=""
BASESCAN_BASE_URL=https://api-v2.basescan.org/api

# --- Indexer ---
LUCENTFLOW_INDEXER_START_BLOCK=44100000

# --- Observability (com.lucentflow package: INFO=quiet steady state, DEBUG=per-block [PERF] traces) ---
LUCENTFLOW_LOGGING_LEVEL_COM_LUCENTFLOW=INFO

# --- Optional ---
PROXY_HOST=""
PROXY_PORT=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
ALERT_MIN_SCORE=70
SPRING_PROFILES_ACTIVE="docker"
JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational -Xms512m -Xmx2g"

# ==============================================================================
# Professional RPC tuning (only when LUCENTFLOW_CHAIN_RPC_URL is NOT mainnet.base.org)
# Example: Alchemy — set URL, point backup at official public RPC, then uncomment and tune:
# ==============================================================================
LUCENTFLOW_INDEXER_POLLING_INTERVAL_MS=800
LUCENTFLOW_INDEXER_MAX_BATCH_SIZE=1500
LUCENTFLOW_INDEXER_MAX_CONCURRENCY=6
LUCENTFLOW_INDEXER_CATCHUP_BOOST_ENABLED=false
LUCENTFLOW_INDEXER_COOLDOWN_WINDOW_MS=60000
LUCENTFLOW_INDEXER_COOLDOWN_POLLING_INTERVAL_MS=15000
LUCENTFLOW_INDEXER_COOLDOWN_MAX_BATCH_SIZE=80
LUCENTFLOW_CHAIN_PROFESSIONAL_INTER_BATCH_SLEEP_MS=1500
LUCENTFLOW_INDEXER_SCHEDULER_TICK_MS=200

# Optional analyzer tuning (defaults: concurrency=2, batch-size=20 if omitted)
# LUCENTFLOW_ANALYZER_CONCURRENCY=2
# LUCENTFLOW_ANALYZER_BATCH_SIZE=20
