# Database Configuration
POSTGRES_DB=lucentflow
POSTGRES_USER=admin
POSTGRES_PASSWORD=lucentflow_pwd

# Network Proxy (Optional - for corporate environments)
PROXY_HOST=127.0.0.1
PROXY_PORT=10808

# Base Network Integration (Mandatory for Genesis Trace)
BASESCAN_API_KEY=
LUCENTFLOW_CHAIN_RPC_URL=https://mainnet.base.org

# Spring Profiles
SPRING_PROFILES_ACTIVE=docker

# JVM Optimization
JAVA_OPTS=-XX:+UseZGC -XX:+ZGenerational -Xms512m -Xmx2g
