# ==============================================================================
# LucentFlow Environment Configuration Template (v1.1.0-SNAPSHOT)
#
# Single source of truth: copy this file to `.env` in this directory (`docker/`)
# and adjust values for your environment.
#
# Guided setup (environment contract):
#   1. Copy to `.env` at this deployment root.
#   2. Fill secrets and RPC URL. Unset keys keep safe defaults where documented below.
#   3. Smart RPC: LUCENTFLOW_CHAIN_RPC_URL drives dynamic backpressure (public vs professional).
#   4. Checkpoints: LUCENTFLOW_INDEXER_START_BLOCK is for first boot only; resume uses sync_status (ID=1).
#
# @author ArchLucent
# ==============================================================================

# --- [DATABASE CONFIGURATION] ---
POSTGRES_DB="lucentflow"
POSTGRES_USER="admin"
# DEFAULT: 'lucentflow_pwd' for one-click local setup.
# SECURITY: Change before any production or grant-demo deployment.
POSTGRES_PASSWORD=lucentflow_pwd

# --- [BLOCKCHAIN NETWORK - BASE L2] ---
# SMART DETECTION: Indexer throughput is tuned from the hostname (Alchemy, QuickNode, Infura, BlastAPI → professional tier).
#   PUBLIC:    Default, conservative concurrency (e.g. https://mainnet.base.org).
#   PROFESSIONAL: Higher RPC parallelism and larger pipeline chunks (paid / dedicated endpoints).
LUCENTFLOW_CHAIN_RPC_URL=https://mainnet.base.org
# Smart RPC (example): Alchemy endpoint triggers PROFESSIONAL mode auto-tuning.
# LUCENTFLOW_CHAIN_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#
# Failover support: JSON-RPC backup endpoint used when the primary returns 4xx/5xx or hits I/O errors.
# Implementation detail: the client enters a 5-minute backup window, then re-attempts the primary.
LUCENTFLOW_CHAIN_RPC_BACKUP_URL=https://mainnet.base.org

# REQUIRED for deep funding traces: Basescan-compatible API (forensics / contract metadata).
# https://basescan.org/apis
BASESCAN_API_KEY=""
BASESCAN_BASE_URL=https://api-v2.basescan.org/api

# --- [SYNC & FORENSICS] ---
# Initial scan height only. After the first run, progress is persisted in PostgreSQL (sync_status, ID=1 protocol).
LUCENTFLOW_INDEXER_START_BLOCK=44000000

# --- [NETWORK PROXY] ---
# Optional: HTTP proxy for outbound RPC if your network requires it.
PROXY_HOST=""
PROXY_PORT=""

# --- [TELEGRAM ALERTS] ---
# Optional: high-risk whale alerts via Bot API. Leave empty to disable.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
ALERT_MIN_SCORE=70

# --- [SYSTEM & PERFORMANCE] ---
# e.g. docker | local — align with your compose or IDE run configuration.
SPRING_PROFILES_ACTIVE="docker"

# JVM 21: ZGC + generational mode; tune heap for indexer + analyzer colocation.
JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational -Xms512m -Xmx2g"
